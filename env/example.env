# Template for env/local.env, env/staging.env, env/production.env.
# Copy this file to one of those names and fill in real values.
# Real env files are gitignored; this template is committed.

# ── Auth ────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET: 32+ char random string used to sign sessions.
# BETTER_AUTH_URL / NEXT_PUBLIC_BETTER_AUTH_URL: full origin (no trailing /).
BETTER_AUTH_SECRET=replace-with-32-char-random-string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ── Google OAuth ────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (SendGrid) ───────────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@your-domain.com

# ── Database (Postgres / Neon) ─────────────────────────────────────
# Use ?sslmode=require&channel_binding=require for Neon.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── API ────────────────────────────────────────────────────────────
# Public origin of the Django backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Skip /pricing redirects (true on local, false in staging/prod).
NEXT_PUBLIC_SKIP_PAYMENT_GATE=true

# ── Sanity (blog CMS) ──────────────────────────────────────────────
NEXT_PUBLIC_SANITY_DATASET="blogs"
NEXT_PUBLIC_SANITY_PROJECT_ID=
